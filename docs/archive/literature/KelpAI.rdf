                <rdf:value>https://www.frontiersin.org/articles/10.3389/ffgc.2022.734330/full</rdf:value>
            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2025-11-24 17:42:17</dcterms:dateSubmitted>
        <bib:pages>734330</bib:pages>
    </bib:Article>
