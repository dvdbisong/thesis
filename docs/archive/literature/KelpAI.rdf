    <bib:Article rdf:about="https://www.sciencedirect.com/science/article/pii/S0957417420300270">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf rdf:resource="urn:issn:0957-4174"/>
        <bib:authors>
            <rdf:Seq>
                <rdf:li>
