        <bib:authors>
            <rdf:Seq>
                <rdf:li>
                    <foaf:Person>
                        <foaf:surname>Wilman</foaf:surname>
                        <foaf:givenName>Elizabeth A.</foaf:givenName>
                    </foaf:Person>
