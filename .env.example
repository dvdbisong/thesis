# =============================================================================
# Environment Variables Template
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control
# =============================================================================

# Backblaze B2 Credentials (S3-compatible)
# Get these from: Backblaze B2 Console > App Keys
AWS_ACCESS_KEY_ID=your_b2_key_id_here
AWS_SECRET_ACCESS_KEY=your_b2_application_key_here

# Optional: Backblaze B2 Endpoint (if not using default)
# B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com

# =============================================================================
# Usage:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual credentials
# 3. Load before running DVC: source .env
# 4. Or use direnv for auto-loading: direnv allow
# =============================================================================
